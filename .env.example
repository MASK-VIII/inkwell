# Copy to ".env.local" in this folder, fill in values, restart Vite.
# https://vite.dev/guide/env-and-mode

# --- Supabase cloud sync (optional) ---
# Dashboard: Project Settings → API → Project URL
# Key: use EITHER legacy anon OR new publishable key (Inkwell accepts both).
# Auth: Authentication → URL configuration (Site URL + Redirect URLs for localhost)
VITE_INKWELL_CLOUD_SYNC=1
# Full project URL from Supabase (must include https://)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# --- Legacy HTTP backup POST (optional, separate from Supabase) ---
# VITE_INKWELL_CLOUD_BACKUP_URL=
# VITE_INKWELL_CLOUD_BACKUP_KEY=
