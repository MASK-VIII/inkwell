# Copy to ".env.local" in this folder, fill in values, restart Vite.
#
# Cursor MCP (Supabase): `.cursor/mcp.json` points at your project. Restart Cursor, open
# Settings → Tools & MCP, complete Supabase OAuth once. Optional PAT: Account → Access Tokens,
# then set user env SUPABASE_ACCESS_TOKEN and change mcp.json to use Bearer ${env:SUPABASE_ACCESS_TOKEN}
# (never commit tokens). MCP manages Supabase only — Paddle keys stay in Edge Function secrets / .env.local.
# https://vite.dev/guide/env-and-mode

# --- Supabase cloud sync (optional) ---
# Dashboard: Project Settings → API → Project URL
# Key: use EITHER legacy anon OR new publishable key (Inkwell accepts both).
# Auth: Authentication → URL configuration (Site URL + Redirect URLs for localhost)
VITE_INKWELL_CLOUD_SYNC=1
# Full project URL from Supabase (must include https://)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# --- Desktop installer (web UI only; Electron hides this) ---
# Link to your hosted NSIS build, e.g. GitHub Releases asset URL ending in .exe
# VITE_INKWELL_DESKTOP_DOWNLOAD_URL=https://example.com/Inkwell-Setup.exe

# --- Legacy HTTP backup POST (optional, separate from Supabase) ---
# VITE_INKWELL_CLOUD_BACKUP_URL=
# VITE_INKWELL_CLOUD_BACKUP_KEY=

# --- Paddle hosted checkout (full URLs from Paddle Dashboard → Catalog / checkout links) ---
# Required for "Unlock Basic" / Pro / upgrade in the app and for ?checkout= deep links from the marketing site.
# VITE_PADDLE_CHECKOUT_EBOOK_SUITE=https://buy.paddle.com/...
# VITE_PADDLE_CHECKOUT_PRO=https://buy.paddle.com/...
# VITE_PADDLE_CHECKOUT_UPGRADE=https://buy.paddle.com/...

# --- Paddle.js overlay checkout (use this if Paddle no longer provides per-product hosted checkout URLs) ---
# Token: Paddle Dashboard → Developer Tools → Authentication → client-side token
#   - test_... tokens → sandbox; live_... → production (Inkwell picks this automatically; env below is a fallback)
# Environment: optional "sandbox" or "production" when the token prefix is missing or ambiguous
# Price IDs: `pri_...` from Paddle Catalog — must be from the SAME Paddle environment as the token (sandbox vs live)
# VITE_PADDLE_ENVIRONMENT=production
# VITE_PADDLE_CLIENT_TOKEN=live_...
# VITE_PADDLE_PRICE_ID_BASIC=pri_...
# VITE_PADDLE_PRICE_ID_PRO=pri_...
# VITE_PADDLE_PRICE_ID_UPGRADE=pri_...

# --- Paddle checkout via Supabase Edge (optional; hosted txn URL) ---
# By default the app uses Paddle.js overlay (Vercel: client token + VITE_PADDLE_PRICE_ID_* only).
# Set to 1 after Edge secrets work: PADDLE_API_KEY, PADDLE_PRICE_IDS_*, optional PADDLE_CHECKOUT_PAGE_URL
#   (https://supabase.com/dashboard/project/_/functions/secrets or: supabase secrets set ...).
# VITE_PADDLE_EDGE_CHECKOUT=1
