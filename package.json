{
  "name": "inkwell",
  "description": "Local-first writing workspace (Inkwell)",
  "author": "Inkwell",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/MASK-VIII/inkwell.git"
  },
  "scripts": {
    "dev": "node scripts/generate-changelog.mjs && vite",
    "dev:desktop": "concurrently -k \"cross-env INKWELL_DESKTOP=1 vite\" \"wait-on http://localhost:5173 && cross-env INKWELL_DESKTOP=1 electron electron/main.cjs\"",
    "dev:desktop:debug": "concurrently -k \"cross-env INKWELL_DESKTOP=1 vite\" \"wait-on http://localhost:5173 && cross-env INKWELL_DESKTOP=1 INKWELL_ELECTRON_DEVTOOLS=1 electron electron/main.cjs\"",
    "build": "node scripts/generate-changelog.mjs && node scripts/generate-sitemap.mjs && node scripts/fetch-desktop-installer-for-vercel.mjs && tsc -b && vite build",
    "prebuild:desktop": "node scripts/prepare-desktop-build.mjs",
    "build:desktop": "npm run generate:brand-icons && tsc -b && cross-env INKWELL_DESKTOP=1 vite build && node scripts/run-desktop-pack.mjs",
    "build:desktop:install": "npm run build:desktop && node scripts/launch-desktop-installer.mjs",
    "desktop:open-release": "explorer release",
    "desktop:run-unpacked": "node scripts/run-unpacked-inkwell.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:brand-icons": "node scripts/generate-brand-icons.mjs",
    "print:desktop-download-url": "node scripts/print-desktop-download-url.mjs",
    "optimize:brand-svg": "svgo public/favicon.svg public/brand/mark-on-light-bg.svg public/brand/candidates/01-well-donut.svg public/brand/candidates/02-ripple.svg public/brand/candidates/03-book-gutter-ink.svg public/brand/candidates/04-bifolium-classic.svg public/brand/candidates/05-ink-monogram.svg"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/dm-serif-display": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/great-vibes": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/libre-baskerville": "^5.2.10",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@paddle/paddle-js": "^1.6.4",
    "@pdf-lib/fontkit": "^1.1.1",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tiptap/extension-character-count": "^3.22.5",
    "@tiptap/extension-horizontal-rule": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-mention": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.22.5",
    "dejavu-fonts-ttf": "^2.37.3",
    "dictionary-en": "^4.0.0",
    "dompurify": "^3.4.2",
    "electron-updater": "^6.8.3",
    "hyphenation.en-us": "^0.2.1",
    "hypher": "^0.2.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "lz-string": "^1.5.0",
    "mammoth": "^1.12.0",
    "nlcst-to-string": "^4.0.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "retext-english": "^5.0.0",
    "retext-indefinite-article": "^5.0.0",
    "retext-passive": "^5.0.0",
    "retext-readability": "^8.0.0",
    "retext-redundant-acronyms": "^5.0.0",
    "retext-repeated-words": "^5.0.0",
    "retext-sentence-spacing": "^6.0.0",
    "retext-simplify": "^8.0.0",
    "retext-spell": "^6.1.0",
    "retext-stringify": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "app.inkwell.desktop",
    "icon": "build/icon.png",
    "productName": "Inkwell",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "fileAssociations": [
      {
        "ext": "inkwell",
        "name": "Inkwell archive",
        "description": "Inkwell manuscript backup (ZIP container)",
        "icon": "build/icon.ico",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "protocols": [
      {
        "name": "Inkwell",
        "schemes": [
          "inkwell"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
