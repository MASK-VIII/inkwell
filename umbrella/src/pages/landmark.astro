---
import Base from '../layouts/Base.astro'
import InkwellPlaybill from '../components/InkwellPlaybill.astro'
import { faqJsonLd, landmarkSoftwareJsonLd } from '../lib/seo'

const sections = [
  {
    eyebrow: 'What it is',
    heading: 'A swipe deck for things to do nearby.',
    body: `Landmark is discovery without the dating baggage. Set a radius, pick a vibe — historical attractions, food and drink, or hidden gems — and swipe through places near you. Right means save it. Left means skip.`,
  },
  {
    eyebrow: 'Why swipe',
    heading: 'Because ranked lists bury the interesting option.',
    body: `Maps win when you already know the pin. Landmark wins when you want something cool within walking or driving distance and would rather decide place-by-place than scroll another top-ten roundup.`,
  },
  {
    eyebrow: 'Who it is for',
    heading: 'Travelers, locals, and anyone with an open afternoon.',
    body: `New city, between meetings, or hunting a quieter corner of your own neighborhood — Landmark fills a deck from your location so “what should we do?” feels like a game, not homework.`,
  },
] as const

const faqs = [
  {
    question: 'Is Landmark a dating app?',
    answer:
      'No. Landmark is for places — historical spots, food and drink, and hidden gems near you. Swipe right to save a place, not a person.',
  },
  {
    question: 'How does Landmark find places?',
    answer:
      'Landmark uses your location and a radius you choose, then shows nearby attractions you can filter by category and save as you swipe.',
  },
  {
    question: 'Where can I use Landmark?',
    answer:
      'Anywhere you open the web app. Results are based on your current area and radius, not a single-city guidebook.',
  },
]
---

<Base
  title="Landmark — Swipe to discover things to do nearby | Enter the Limelight"
  description="Landmark helps you find cool things to do nearby with a simple swipe: historical attractions, food and drink, and hidden gems inside your radius. Save favorites; skip the rest."
  keywords="Landmark app, things to do nearby, swipe to discover, historical attractions, hidden gems, food and drink near me, travel discovery app, local attractions"
  jsonLd={[landmarkSoftwareJsonLd(), faqJsonLd(faqs)]}
>
  <main>
    <section class="page-hero">
      <div class="container page-hero-inner">
        <p class="eyebrow">Swipe to discover nearby</p>
        <h1 class="display page-hero-title">Landmark</h1>
        <p class="lede page-hero-lede">
          Find historical spots, food and drink, and hidden gems near you —
          one card at a time. Save what earns a right swipe.
        </p>
        <div class="page-hero-actions">
          <a class="btn btn-primary" href="https://landmark.enterthelimelight.com">
            Open Landmark
          </a>
          <a class="btn btn-secondary" href="/journal/swipe-to-discover-with-landmark">
            How it works
          </a>
        </div>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-playbill">
      <div class="container">
        <InkwellPlaybill
          titleId="landmark-playbill"
          href="https://landmark.enterthelimelight.com"
          ctaLabel="Start discovering"
          title="Landmark"
          blurb="Not dating. Just places. Set your radius, pick a category, and swipe through attractions near you — with more detail a scroll away before you decide."
          bullets={[
            'Works wherever you are — location + radius, not a static city list',
            'Historical, food & drink, and hidden gems',
            'Save the keepers; skip the rest',
          ]}
          screenshotSrc={null}
        />
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-pillars">
      <div class="container pillars">
        {
          sections.map((s) => (
            <article class="pillar">
              <p class="eyebrow">{s.eyebrow}</p>
              <h2 class="pillar-heading">{s.heading}</h2>
              <p class="pillar-body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-detail" aria-labelledby="landmark-detail">
      <div class="container detail">
        <h2 id="landmark-detail" class="detail-heading">
          Categories that match how people actually explore
        </h2>
        <p>
          Use <strong>Historical</strong> when you want museums, monuments, and
          heritage. Use <strong>Food &amp; drink</strong> when the afternoon
          needs a table. Use <strong>Hidden gems</strong> when you want the
          quieter find — viewpoints, gardens, galleries — that ranked lists often
          skip. Or leave the filter on All and let the deck surprise you.
        </p>
        <p>
          Full walkthrough:
          <a href="/journal/swipe-to-discover-with-landmark">
            Swipe to discover cool things nearby with Landmark
          </a>
          .
        </p>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-faq" aria-labelledby="landmark-faq">
      <div class="container faq">
        <p class="eyebrow">FAQ</p>
        <h2 id="landmark-faq" class="faq-title">Landmark questions</h2>
        <dl class="faq-list">
          {
            faqs.map((faq) => (
              <div class="faq-item">
                <dt>{faq.question}</dt>
                <dd>{faq.answer}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-finalcta">
      <div class="container finalcta">
        <h2 class="finalcta-heading">Go find something.</h2>
        <p class="finalcta-body">
          Landmark is live on the web. Open it, allow location, set a radius, and
          start swiping.
        </p>
        <a class="btn btn-primary" href="https://landmark.enterthelimelight.com">
          Open Landmark
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  .page-hero {
    padding: clamp(3.5rem, 10vw, 6rem) 0 clamp(2rem, 5vw, 3.5rem);
  }

  .page-hero-inner {
    text-align: center;
    max-width: 40rem;
    margin: 0 auto;
  }

  .page-hero-title {
    margin: 0.75rem 0 1rem;
  }

  .page-hero-lede {
    margin: 0 auto;
  }

  .page-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  .pillars {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    grid-template-columns: 1fr;
  }

  .pillar {
    border: 1px solid var(--rule-gold);
    background: var(--color-stage-elevated);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .pillar-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.6vw, 1.8rem);
    line-height: 1.2;
    color: var(--color-cream);
    margin: 0.5rem 0 0.75rem;
  }

  .pillar-body {
    color: var(--color-cream-dim);
    margin: 0;
    line-height: 1.65;
  }

  @media (min-width: 760px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .detail {
    max-width: 40rem;
    margin: 0 auto;
  }

  .detail-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    margin: 0 0 1rem;
    color: var(--color-cream);
  }

  .detail p {
    color: var(--color-cream-dim);
    line-height: 1.7;
  }

  .detail strong {
    color: var(--color-cream);
  }

  .detail a {
    color: var(--color-gold-bright);
  }

  .faq {
    max-width: 40rem;
    margin: 0 auto;
  }

  .faq-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3vw, 2.25rem);
    margin: 0.75rem 0 1.5rem;
    color: var(--color-cream);
  }

  .faq-list {
    margin: 0;
  }

  .faq-item {
    border-top: 1px solid var(--rule-gold);
    padding: 1.1rem 0;
  }

  .faq-item dt {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-cream);
    margin-bottom: 0.45rem;
  }

  .faq-item dd {
    margin: 0;
    color: var(--color-cream-dim);
    line-height: 1.6;
  }

  .finalcta {
    text-align: center;
    max-width: 32rem;
    margin: 0 auto;
  }

  .finalcta-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 1rem;
    color: var(--color-cream);
  }

  .finalcta-body {
    color: var(--color-cream-dim);
    margin: 0 0 1.75rem;
  }
</style>
