---
import Base from '../layouts/Base.astro'
const year = new Date().getFullYear()
---

<Base
  title="Enter the Limelight"
  description="The home of Inkwell, a workspace built for the long form, and what comes next."
>
  <main class="page">
    <header class="hero">
      <a class="brand" href="/" aria-label="Enter the Limelight">
        <svg
          class="brand-mark"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 32 32"
          aria-hidden="true"
        >
          <path fill="#2c241f" d="M10.5 22.5v-12l5.8-2v14.2l-5.8 1.8z" opacity=".88"></path>
          <path fill="#2c241f" d="m16.3 8.5 5.8 2v12l-5.8-1.8z" opacity=".72"></path>
          <circle cx="16" cy="12.5" r="2.6" fill="#2c241f"></circle>
        </svg>
        <span class="brand-name">Enter the Limelight</span>
      </a>

      <p class="tagline">A small studio for ambitious writing tools and the stories they help finish.</p>

      <h1 class="lede">
        The home of <em>Inkwell</em>, and what comes next.
      </h1>
    </header>

    <section class="card" aria-labelledby="inkwell-heading">
      <p class="card-eyebrow">Now in beta</p>
      <h2 id="inkwell-heading" class="card-title">Inkwell</h2>
      <p class="card-body">
        A workspace built for the long form. Chapters, drafts, revisions, and the small editorial
        decisions that turn a manuscript into a book.
      </p>
      <a class="card-cta" href="https://inkwell.enterthelimelight.com">
        Open Inkwell
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </section>

    <p class="more">More coming soon.</p>

    <footer class="footer">
      <p>&copy; {year} Enter the Limelight.</p>
      <p>
        <a href="mailto:inkwell@enterthelimelight.com">inkwell@enterthelimelight.com</a>
      </p>
    </footer>
  </main>
</Base>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem 2rem;
    gap: 3rem;
    text-align: center;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 36rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--color-ink);
  }

  .brand-mark {
    height: 1.75rem;
    width: 1.75rem;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    letter-spacing: -0.01em;
  }

  .tagline {
    margin: 0;
    color: rgba(139, 69, 19, 0.85);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 30rem;
  }

  .lede {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .lede em {
    font-style: italic;
    color: var(--color-walnut);
  }

  .card {
    width: 100%;
    max-width: 30rem;
    padding: 2.25rem 1.75rem;
    border: 1px solid rgba(212, 195, 168, 0.7);
    background: var(--color-white-soft);
    border-radius: 1.25rem;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.5) inset, 0 8px 32px rgba(44, 36, 31, 0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .card-eyebrow {
    margin: 0;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(139, 69, 19, 0.75);
  }

  .card-title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 2rem;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }

  .card-body {
    margin: 0;
    color: rgba(139, 69, 19, 0.95);
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 26rem;
  }

  .card-cta {
    margin-top: 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.6rem;
    background: var(--color-ink);
    color: var(--color-parchment);
    border-radius: 9999px;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 160ms ease;
  }

  .card-cta:hover,
  .card-cta:focus-visible {
    background: var(--color-walnut);
    outline: none;
  }

  .more {
    margin: 0;
    color: rgba(139, 69, 19, 0.7);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    font-style: italic;
  }

  .footer {
    margin-top: auto;
    padding-top: 2rem;
    color: rgba(139, 69, 19, 0.7);
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .footer a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid rgba(139, 69, 19, 0.3);
  }

  .footer a:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-ink);
  }
</style>
