---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import BrandMark from '../components/BrandMark.astro'
import InkwellPlaybill from '../components/InkwellPlaybill.astro'
import JournalCard from '../components/JournalCard.astro'
import SubscribeCard from '../components/SubscribeCard.astro'

const allPosts = (await getCollection('journal', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)
const latestPosts = allPosts.slice(0, 2)
---

<Base
  title="Enter the Limelight"
  description="A small studio building Inkwell — a chapter-first writing app for new authors and seasoned novelists — and what comes next."
>
  <main class="home">
    <section class="hero">
      <div class="container hero-inner">
        <BrandMark size={36} withWordmark={false} />
        <p class="eyebrow hero-eyebrow">A small writing studio</p>
        <h1 class="display hero-display">
          The home of <em>Inkwell</em>,<br />and what comes next.
        </h1>
        <p class="lede hero-lede">
          Tools and stories for writers at the start of the climb — and for the
          ones who never quite stopped climbing.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://inkwell.enterthelimelight.com">
            Open Inkwell
          </a>
          <a class="btn btn-secondary" href="/inkwell">Tour the app</a>
        </div>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-playbill">
      <div class="container">
        <InkwellPlaybill />
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-founder">
      <div class="container founder">
        <p class="eyebrow">From the studio</p>
        <h2 class="founder-heading">
          One person, building tools for the books they wish existed.
        </h2>
        <p class="founder-body">
          Inkwell is the writing app I needed when I was just starting out — and
          the one I still want now that I'm not. The Limelight studio is where
          that work happens, in the open, one chapter at a time.
        </p>
        <p class="founder-cta">
          <a href="/about">Read the founder's note &rarr;</a>
        </p>
      </div>
    </section>

    {
      latestPosts.length > 0 && (
        <>
          <hr class="divider-rule" />
          <section class="section section-journal">
            <div class="container journal-section">
              <header class="journal-section-head">
                <p class="eyebrow">From the journal</p>
                <h2 class="journal-section-title">Letters from the studio</h2>
                <a class="journal-section-more" href="/journal">
                  All posts &rarr;
                </a>
              </header>
              <div class="journal-section-list">
                {latestPosts.map((post) => (
                  <JournalCard
                    href={`/journal/${post.slug}`}
                    title={post.data.title}
                    description={post.data.description}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                  />
                ))}
              </div>
            </div>
          </section>
        </>
      )
    }

    <hr class="divider-rule" />

    <section class="section section-subscribe">
      <div class="container">
        <SubscribeCard />
      </div>
    </section>
  </main>
</Base>

<style>
  .home {
    padding-bottom: 1rem;
  }

  .hero {
    padding: clamp(4rem, 12vw, 7rem) 0 clamp(2rem, 6vw, 4rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .hero-eyebrow {
    margin-top: 1rem;
  }

  .hero-display {
    margin-top: 0.5rem;
  }

  .hero-display em {
    font-style: italic;
    color: var(--color-blood-glow);
  }

  .hero-lede {
    margin-top: 0.5rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.85rem;
    margin-top: 1.75rem;
  }

  .founder {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto;
  }

  .founder-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3.5vw, 2.4rem);
    line-height: 1.2;
    margin: 1rem 0;
    color: var(--color-cream);
  }

  .founder-body {
    color: var(--color-cream-dim);
    margin: 0 auto;
    max-width: 32rem;
  }

  .founder-cta {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .founder-cta a {
    border-bottom: 0;
    color: var(--color-gold-bright);
  }

  .journal-section-head {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 0.75rem 1.5rem;
    margin-bottom: 1.25rem;
  }

  .journal-section-title {
    grid-column: 1 / -1;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3vw, 2.25rem);
    line-height: 1.15;
    margin: 0.35rem 0 0;
    color: var(--color-cream);
  }

  .journal-section-more {
    grid-row: 1;
    grid-column: 2;
    align-self: start;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-gold);
    border-bottom: 0;
  }

  .journal-section-list > :first-child {
    border-top: 1px solid var(--rule-gold-strong);
  }

  @media (max-width: 540px) {
    .journal-section-head {
      grid-template-columns: 1fr;
    }
    .journal-section-more {
      grid-column: 1;
    }
  }
</style>
