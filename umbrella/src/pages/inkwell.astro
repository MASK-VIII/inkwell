---
import Base from '../layouts/Base.astro'
import InkwellPlaybill from '../components/InkwellPlaybill.astro'

const sections = [
  {
    eyebrow: 'What it is',
    heading: 'A chapter-first writing app for new and seasoned authors.',
    body: `Inkwell is a manuscript-shaped editor. You write chapters, not files. You see your book as a book — a spine of chapters with everything else (notes, drafts, research) hanging off it — instead of as a tangle of documents you have to keep track of in your head.`,
  },
  {
    eyebrow: 'Why it exists',
    heading: 'Because the existing tools forgot the writer just starting out.',
    body: `Most writing software is built for people who have already written several books. Inkwell is built for the chapter you have not finished yet — and it stays useful all the way to the tenth book and the twentieth print run.`,
  },
  {
    eyebrow: 'Who it is for',
    heading: 'Anyone trying to finish a manuscript.',
    body: `New authors who need a runway, working novelists who want a single calm place to write, and self-publishers who care about the printed book at the end. If a chapter is the unit of your work, Inkwell will fit your hand.`,
  },
] as const
---

<Base
  title="Inkwell — Enter the Limelight"
  description="Inkwell is a chapter-first writing app for new and seasoned authors: offline-first, calm, and shaped like a manuscript."
>
  <main>
    <section class="page-hero">
      <div class="container page-hero-inner">
        <p class="eyebrow">The Limelight Presents</p>
        <h1 class="display page-hero-title">Inkwell</h1>
        <p class="lede page-hero-lede">
          A chapter-first writing app — calm, offline-by-default, and shaped
          like the book you're trying to finish.
        </p>
        <div class="page-hero-actions">
          <a class="btn btn-primary" href="https://inkwell.enterthelimelight.com">
            Open Inkwell
          </a>
          <a class="btn btn-secondary" href="https://inkwell.enterthelimelight.com/buy">
            See pricing
          </a>
        </div>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-playbill">
      <div class="container">
        <InkwellPlaybill ctaLabel="Start writing in Inkwell" />
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-pillars">
      <div class="container pillars">
        {
          sections.map((s) => (
            <article class="pillar">
              <p class="eyebrow">{s.eyebrow}</p>
              <h2 class="pillar-heading">{s.heading}</h2>
              <p class="pillar-body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-finalcta">
      <div class="container finalcta">
        <h2 class="finalcta-heading">Ready when you are.</h2>
        <p class="finalcta-body">
          Inkwell runs in your browser, works offline, and never asks for an
          account before you start writing. Your manuscript stays on your
          machine until you decide otherwise.
        </p>
        <a class="btn btn-primary" href="https://inkwell.enterthelimelight.com">
          Open Inkwell
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  .page-hero {
    padding: clamp(3rem, 8vw, 5rem) 0 clamp(1.5rem, 4vw, 2.5rem);
  }

  .page-hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .page-hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
  }

  .page-hero-lede {
    margin-top: 0.5rem;
  }

  .page-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .pillars {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    grid-template-columns: 1fr;
  }

  .pillar {
    border: 1px solid var(--rule-gold);
    background: var(--color-stage-elevated);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .pillar-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.6vw, 1.8rem);
    line-height: 1.2;
    color: var(--color-cream);
    margin: 0.5rem 0 0.75rem;
  }

  .pillar-body {
    color: var(--color-cream-dim);
    margin: 0;
    line-height: 1.65;
  }

  @media (min-width: 760px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .finalcta {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
  }

  .finalcta-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.85rem, 4vw, 2.5rem);
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-cream);
  }

  .finalcta-body {
    color: var(--color-cream-dim);
    margin: 0 auto 1.75rem;
  }
</style>
