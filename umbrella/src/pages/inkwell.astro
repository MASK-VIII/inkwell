---
import Base from '../layouts/Base.astro'
import InkwellPlaybill from '../components/InkwellPlaybill.astro'
import { faqJsonLd, inkwellSoftwareJsonLd } from '../lib/seo'

const sections = [
  {
    eyebrow: 'What it is',
    heading: 'Free local-first writing software for novels.',
    body: `Inkwell is a manuscript-shaped editor. You write chapters, not files. You see your book as a spine of chapters — with notes, drafts, and research hanging off it — instead of as a tangle of documents you have to keep track of in your head.`,
  },
  {
    eyebrow: 'Why it is free',
    heading: 'No account. No subscription. No export paywall.',
    body: `We removed cloud sync and billing from the product so the core job stays clear: finish the manuscript. EPUB, print-ready PDF, DOCX, Markdown, and plain text exports are unlocked. Your library stays on your device.`,
  },
  {
    eyebrow: 'Who it is for',
    heading: 'Anyone trying to finish a manuscript.',
    body: `New authors who need a runway, working novelists who want a calm chapter spine, and self-publishers who care about the printed book at the end. If a chapter is the unit of your work, Inkwell will fit your hand.`,
  },
] as const

const faqs = [
  {
    question: 'Is Inkwell really free?',
    answer:
      'Yes. Inkwell is free writing software with no subscription. You can draft and export without creating an account or paying to unlock formats.',
  },
  {
    question: 'Does Inkwell sync to the cloud?',
    answer:
      'No. Inkwell is local-first. Manuscripts stay in the browser or Windows desktop app. Use portable .inkwell.zip backups when you want a file you control.',
  },
  {
    question: 'What can I export from Inkwell?',
    answer:
      'Inkwell exports EPUB, print-ready PDF, DOCX, Markdown, and plain text — unlocked for free.',
  },
]
---

<Base
  title="Inkwell — Free local-first novel writing software | Enter the Limelight"
  description="Inkwell is free chapter-first writing software for novels: local-only manuscripts, no account required, and unlocked EPUB, print-ready PDF, DOCX, and Markdown exports."
  keywords="Inkwell, free novel writing software, local-first writing app, chapter-first editor, EPUB export, print-ready PDF, offline writing software, self-publishing tools"
  jsonLd={[inkwellSoftwareJsonLd(), faqJsonLd(faqs)]}
>
  <main>
    <section class="page-hero">
      <div class="container page-hero-inner">
        <p class="eyebrow">Free writing software for novels</p>
        <h1 class="display page-hero-title">Inkwell</h1>
        <p class="lede page-hero-lede">
          Chapter-first drafting, local-only manuscripts, and unlocked publishing
          exports — without a subscription or signup wall.
        </p>
        <div class="page-hero-actions">
          <a class="btn btn-primary" href="https://inkwell.enterthelimelight.com">
            Open Inkwell free
          </a>
          <a class="btn btn-secondary" href="/journal/inkwell-is-free-and-local-first">
            Why it is free
          </a>
        </div>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-playbill">
      <div class="container">
        <InkwellPlaybill ctaLabel="Start writing in Inkwell" />
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-pillars">
      <div class="container pillars">
        {
          sections.map((s) => (
            <article class="pillar">
              <p class="eyebrow">{s.eyebrow}</p>
              <h2 class="pillar-heading">{s.heading}</h2>
              <p class="pillar-body">{s.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-detail" aria-labelledby="inkwell-detail">
      <div class="container detail">
        <h2 id="inkwell-detail" class="detail-heading">
          Built like a book — owned like a file
        </h2>
        <p>
          Most writing apps optimize for accounts, sync, and upgrades. Inkwell
          optimizes for the next chapter. Start in the browser, keep working
          offline-friendly, and export when the draft earns a trip to KDP or
          another retailer. Prefer a desktop install? Use the Windows build from
          GitHub Releases.
        </p>
        <p>
          Read the studio note:
          <a href="/journal/inkwell-is-free-and-local-first">
            Inkwell is free and local-first
          </a>
          .
        </p>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-faq" aria-labelledby="inkwell-faq">
      <div class="container faq">
        <p class="eyebrow">FAQ</p>
        <h2 id="inkwell-faq" class="faq-title">Inkwell questions</h2>
        <dl class="faq-list">
          {
            faqs.map((faq) => (
              <div class="faq-item">
                <dt>{faq.question}</dt>
                <dd>{faq.answer}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <hr class="divider-rule" />

    <section class="section section-finalcta">
      <div class="container finalcta">
        <h2 class="finalcta-heading">Ready when you are.</h2>
        <p class="finalcta-body">
          Inkwell runs in your browser, works without an account, and never asks
          you to pay before you can export the book you wrote.
        </p>
        <a class="btn btn-primary" href="https://inkwell.enterthelimelight.com">
          Open Inkwell
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  .page-hero {
    padding: clamp(3rem, 8vw, 5rem) 0 clamp(1.5rem, 4vw, 2.5rem);
  }

  .page-hero-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .page-hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1;
  }

  .page-hero-lede {
    margin-top: 0.5rem;
  }

  .page-hero-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .pillars {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    grid-template-columns: 1fr;
  }

  .pillar {
    border: 1px solid var(--rule-gold);
    background: var(--color-stage-elevated);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }

  .pillar-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.4rem, 2.6vw, 1.8rem);
    line-height: 1.2;
    color: var(--color-cream);
    margin: 0.5rem 0 0.75rem;
  }

  .pillar-body {
    color: var(--color-cream-dim);
    margin: 0;
    line-height: 1.65;
  }

  @media (min-width: 760px) {
    .pillars {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .detail {
    max-width: 40rem;
    margin: 0 auto;
  }

  .detail-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3vw, 2.2rem);
    margin: 0 0 1rem;
    color: var(--color-cream);
  }

  .detail p {
    color: var(--color-cream-dim);
    line-height: 1.7;
  }

  .detail a {
    color: var(--color-gold-bright);
  }

  .faq {
    max-width: 40rem;
    margin: 0 auto;
  }

  .faq-title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.65rem, 3vw, 2.25rem);
    margin: 0.75rem 0 1.5rem;
    color: var(--color-cream);
  }

  .faq-list {
    margin: 0;
  }

  .faq-item {
    border-top: 1px solid var(--rule-gold);
    padding: 1.1rem 0;
  }

  .faq-item dt {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-cream);
    margin-bottom: 0.45rem;
  }

  .faq-item dd {
    margin: 0;
    color: var(--color-cream-dim);
    line-height: 1.6;
  }

  .finalcta {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto;
  }

  .finalcta-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.85rem, 4vw, 2.5rem);
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--color-cream);
  }

  .finalcta-body {
    color: var(--color-cream-dim);
    margin: 0 auto 1.75rem;
  }
</style>
